FINNHUB_API_KEY=your_finnhub_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Schedule (cron syntax) ────────────────────────────────────────────────────
# Examples:
#   Every 15 minutes during market hours: */15 9-16 * * 1-5
#   Every 30 minutes:                     */30 * * * *
#   Every hour:                           0 * * * *
CRON_SCHEDULE=*/15 9-16 * * 1-5

# ── Behaviour ─────────────────────────────────────────────────────────────────
# Run immediately on startup before waiting for cron
RUN_ON_START=true

# Only analyze during US market hours (Mon–Fri 09:30–16:00 ET)
MARKET_HOURS_ONLY=true

# ── Notifications (fill in when ready) ────────────────────────────────────────
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
# TELEGRAM_BOT_TOKEN=your_telegram_bot_token
# TELEGRAM_CHAT_ID=your_chat_id
